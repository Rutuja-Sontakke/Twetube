DB : try catch

Database is always in another contetient. async await must have to use.

use always IIFE 
;( async () => {
    try {
        await mongoose.connect(`${process.env.MONGODB_URL}/${DB_NAME}`)
        
    } 
    catch (err) {
        console.error("ERROR", err);
        throw err;
    }

}) //IIFE


